# Puerto del servidor
PORT=5000

# MongoDB connection string
# Local: mongodb://localhost:27017/rominanails
# Atlas: mongodb+srv://usuario:password@cluster.mongodb.net/rominanails
MONGODB_URI=mongodb://localhost:27017/rominanails

# Secret para firmar tokens JWT (cambiar en producción!)
JWT_SECRET=cambiar_esta_clave_en_produccion

# Entorno: development | production
NODE_ENV=development

# URL del frontend (para CORS en producción)
# Ejemplo: https://tu-app.vercel.app
CLIENT_URL=http://localhost:5173
